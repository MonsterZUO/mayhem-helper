{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MayhemHelper",
  "version": "0.1.4",
  "identifier": "com.mayhemhelper.aram",
  "build": {
    "removeUnusedCommands": true,
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1422",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Nidalee - 高性能、体积小巧的智能英雄联盟游戏助手",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "decorations": false,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "海克斯大乱斗浮层",
        "width": 360,
        "height": 640,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/mayhem-snapshot.json"
    ],
    "externalBin": [],
    "copyright": "Copyright © 2024 Nidalee Team. All rights reserved.",
    "category": "Game",
    "shortDescription": "高性能、体积小巧的智能英雄联盟游戏助手",
    "longDescription": "Nidalee 是一个高性能、体积小巧的智能英雄联盟游戏助手，提供实时游戏数据分析、自动化功能和个性化设置。",
    "publisher": "Nidalee Team",
    "homepage": "https://github.com/codexlin/Nidalee",
    "licenseFile": "../LICENSE",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null,
      "tsp": false,
      "wix": {
        "language": "zh-CN"
      },
      "allowDowngrades": true
    }
  },
  "plugins": {
    "dialog": null,
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3MERFNDNENDVDNjFGQkUKUldTK0g4WkZQZVFOVjFZSGhYejA5T0s4Z2g5TG5xME8xakNBdmdJR3phMTFOOHZwdWlQMUpqM2YK",
      "endpoints": [
        "https://github.com/MonsterZUO/mayhem-helper/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
